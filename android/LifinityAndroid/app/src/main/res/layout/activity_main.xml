<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app_clay"
    android:fillViewport="true"
    tools:context=".MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/space_screen"
        android:paddingBottom="32dp">

        <!-- ===== CARTÃO DE BOAS-VINDAS ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:background="@drawable/bg_card_clay"
            android:elevation="10dp"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Lifinity"
                android:textColor="@color/lifinity_primary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:letterSpacing="0.1" />

            <!-- Saudação dinâmica com o nome do utilizador -->
            <TextView
                android:id="@+id/greetingText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textColor="@color/lifinity_primary"
                android:textSize="26sp"
                android:textStyle="bold"
                tools:text="Olá, Telmo!" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Tudo pronto para hoje?"
                android:textColor="@color/lifinity_text_secondary"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- ===== GRELHA DE BOTÕES 2 COLUNAS ===== -->

        <!-- Linha 1: Atividades | Ranking -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnTasks"
                android:layout_width="0dp"
                android:layout_height="@dimen/height_button"
                android:layout_weight="1"
                android:background="@drawable/btn_primary_clay"
                android:elevation="6dp"
                android:text="Atividades"
                android:textAllCaps="false"
                android:textColor="@color/lifinity_text_on_primary"
                android:textSize="14sp"
                android:textStyle="bold" />

            <View
                android:layout_width="10dp"
                android:layout_height="1dp" />

            <Button
                android:id="@+id/btnRanking"
                android:layout_width="0dp"
                android:layout_height="@dimen/height_button"
                android:layout_weight="1"
                android:background="@drawable/btn_secondary_clay"
                android:elevation="5dp"
                android:text="Ranking"
                android:textAllCaps="false"
                android:textColor="@color/lifinity_text"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Linha 2: Perfil | Estatísticas -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnProfile"
                android:layout_width="0dp"
                android:layout_height="@dimen/height_button"
                android:layout_weight="1"
                android:background="@drawable/btn_secondary_clay"
                android:elevation="5dp"
                android:text="Perfil"
                android:textAllCaps="false"
                android:textColor="@color/lifinity_text"
                android:textSize="14sp"
                android:textStyle="bold" />

            <View
                android:layout_width="10dp"
                android:layout_height="1dp" />

            <Button
                android:id="@+id/btnStatistics"
                android:layout_width="0dp"
                android:layout_height="@dimen/height_button"
                android:layout_weight="1"
                android:background="@drawable/btn_secondary_clay"
                android:elevation="5dp"
                android:text="Estatísticas"
                android:textAllCaps="false"
                android:textColor="@color/lifinity_text"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Linha 3: Inspiração | Notificações -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnInspiration"
                android:layout_width="0dp"
                android:layout_height="@dimen/height_button"
                android:layout_weight="1"
                android:background="@drawable/btn_secondary_clay"
                android:elevation="5dp"
                android:text="Inspiração"
                android:textAllCaps="false"
                android:textColor="@color/lifinity_text"
                android:textSize="14sp"
                android:textStyle="bold" />

            <View
                android:layout_width="10dp"
                android:layout_height="1dp" />

            <Button
                android:id="@+id/btnNotifications"
                android:layout_width="0dp"
                android:layout_height="@dimen/height_button"
                android:layout_weight="1"
                android:background="@drawable/btn_secondary_clay"
                android:elevation="5dp"
                android:text="Notificações"
                android:textAllCaps="false"
                android:textColor="@color/lifinity_text"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Linha 4: Assistente IA | Chat -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnAssistant"
                android:layout_width="0dp"
                android:layout_height="@dimen/height_button"
                android:layout_weight="1"
                android:background="@drawable/btn_secondary_clay"
                android:elevation="5dp"
                android:text="Assistente IA"
                android:textAllCaps="false"
                android:textColor="@color/lifinity_text"
                android:textSize="14sp"
                android:textStyle="bold" />

            <View
                android:layout_width="10dp"
                android:layout_height="1dp" />

            <Button
                android:id="@+id/btnChat"
                android:layout_width="0dp"
                android:layout_height="@dimen/height_button"
                android:layout_weight="1"
                android:background="@drawable/btn_secondary_clay"
                android:elevation="5dp"
                android:text="Chat"
                android:textAllCaps="false"
                android:textColor="@color/lifinity_text"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Linha 5: Conquistas | Definições -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnAchievements"
                android:layout_width="0dp"
                android:layout_height="@dimen/height_button"
                android:layout_weight="1"
                android:background="@drawable/btn_secondary_clay"
                android:elevation="5dp"
                android:text="Conquistas"
                android:textAllCaps="false"
                android:textColor="@color/lifinity_text"
                android:textSize="14sp"
                android:textStyle="bold" />

            <View
                android:layout_width="10dp"
                android:layout_height="1dp" />

            <Button
                android:id="@+id/btnSettings"
                android:layout_width="0dp"
                android:layout_height="@dimen/height_button"
                android:layout_weight="1"
                android:background="@drawable/btn_secondary_clay"
                android:elevation="5dp"
                android:text="Definições"
                android:textAllCaps="false"
                android:textColor="@color/lifinity_text"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- ===== BOTÃO DE LOGOUT (separado no fundo) ===== -->
        <Button
            android:id="@+id/logoutButton"
            android:layout_width="match_parent"
            android:layout_height="@dimen/height_button"
            android:background="@drawable/btn_danger_clay"
            android:elevation="6dp"
            android:text="Terminar sessão"
            android:textAllCaps="false"
            android:textColor="@color/lifinity_text_on_primary"
            android:textSize="15sp"
            android:textStyle="bold" />
    </LinearLayout>
</ScrollView>
