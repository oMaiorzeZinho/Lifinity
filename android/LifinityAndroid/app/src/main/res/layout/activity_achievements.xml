<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app_clay"
    android:orientation="vertical"
    tools:context=".AchievementsActivity">

    <!-- ===== CABEÇALHO COM BOTÃO VOLTAR ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="12dp">

        <TextView
            android:id="@+id/achievementsBackButton"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:background="@drawable/bg_card_soft_clay"
            android:elevation="4dp"
            android:gravity="center"
            android:text="‹"
            android:textColor="@color/lifinity_text"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_weight="1"
            android:text="Conquistas"
            android:textColor="@color/lifinity_text"
            android:textSize="20sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Subtítulo -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingBottom="12dp"
        android:text="Acompanha tudo o que ja desbloqueaste no Lifinity."
        android:textColor="@color/lifinity_text_secondary"
        android:textSize="14sp" />

    <ProgressBar
        android:id="@+id/achievementsProgressBar"
        style="?android:attr/progressBarStyleLarge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="40dp"
        android:indeterminateTint="@color/lifinity_primary"
        android:visibility="gone"
        tools:visibility="visible" />

    <TextView
        android:id="@+id/achievementsErrorText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginTop="34dp"
        android:gravity="center"
        android:textColor="@color/lifinity_danger"
        android:textSize="15sp"
        android:textStyle="bold"
        android:visibility="gone"
        tools:text="Nao foi possivel carregar conquistas."
        tools:visibility="visible" />

    <TextView
        android:id="@+id/achievementsEmptyText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginTop="34dp"
        android:gravity="center"
        android:text="Ainda nao existem conquistas para mostrar."
        android:textColor="@color/lifinity_text_secondary"
        android:textSize="16sp"
        android:visibility="gone"
        tools:visibility="visible" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/achievementsRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="8dp"
        android:paddingBottom="20dp"
        android:visibility="gone"
        tools:listitem="@layout/item_achievement"
        tools:visibility="visible" />
</LinearLayout>
