<?xml version="1.0" encoding="utf-8"?>
<!-- Bolha de mensagem recebida de outro utilizador — alinhada à esquerda, fundo escuro -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="7dp">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="start"
        android:background="@drawable/bg_card_soft_clay"
        android:elevation="4dp"
        android:orientation="vertical"
        android:padding="@dimen/space_card">

        <TextView
            android:id="@+id/chatMessageText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxWidth="260dp"
            android:textColor="@color/lifinity_text"
            android:textSize="15sp"
            tools:text="Estou bem, obrigado!" />
    </LinearLayout>
</FrameLayout>
