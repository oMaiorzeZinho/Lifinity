<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    android:background="@drawable/bg_card_clay"
    android:elevation="8dp"
    android:orientation="vertical"
    android:padding="@dimen/space_card">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/achievementNameText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/lifinity_text"
            android:textSize="18sp"
            android:textStyle="bold"
            tools:text="Primeira atividade" />

        <TextView
            android:id="@+id/achievementHighlightedText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:background="@drawable/btn_primary_clay"
            android:paddingStart="10dp"
            android:paddingTop="4dp"
            android:paddingEnd="10dp"
            android:paddingBottom="4dp"
            android:text="Destacada"
            android:textColor="@color/lifinity_text_on_primary"
            android:textSize="11sp"
            android:textStyle="bold"
            android:visibility="gone"
            tools:visibility="visible" />
    </LinearLayout>

    <TextView
        android:id="@+id/achievementDescriptionText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textColor="@color/lifinity_text_secondary"
        android:textSize="14sp"
        tools:text="Conclui a tua primeira atividade." />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:background="@drawable/bg_card_soft_clay"
        android:orientation="horizontal"
        android:padding="14dp">

        <TextView
            android:id="@+id/achievementCategoryText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/lifinity_text_secondary"
            android:textSize="13sp"
            android:textStyle="bold"
            tools:text="Categoria: Level" />

        <TextView
            android:id="@+id/achievementStateText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:textColor="@color/lifinity_primary"
            android:textSize="13sp"
            android:textStyle="bold"
            tools:text="Desbloqueada" />
    </LinearLayout>
</LinearLayout>
