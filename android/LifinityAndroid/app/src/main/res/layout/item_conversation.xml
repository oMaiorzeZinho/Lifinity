<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="7dp"
    android:background="@drawable/bg_card_soft_clay"
    android:elevation="5dp"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="@dimen/space_card">

    <!-- Conteúdo principal: nome + última mensagem -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/convNameText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/lifinity_text"
            android:textSize="16sp"
            android:textStyle="bold"
            tools:text="Ana Silva" />

        <TextView
            android:id="@+id/convLastMessageText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="#AAAAAA"
            android:textSize="13sp"
            tools:text="Então, para amanhã?" />
    </LinearLayout>

    <!-- Coluna da direita: data + badge de não lidas -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:gravity="center_horizontal"
        android:orientation="vertical">

        <TextView
            android:id="@+id/convDateText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#888888"
            android:textSize="11sp"
            tools:text="14:30" />

        <!-- Badge de mensagens não lidas (oculto se zero) -->
        <TextView
            android:id="@+id/convUnreadBadge"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:layout_marginTop="6dp"
            android:gravity="center"
            android:textColor="@color/lifinity_text_on_primary"
            android:textSize="11sp"
            android:textStyle="bold"
            android:visibility="gone"
            tools:text="3"
            tools:visibility="visible" />
    </LinearLayout>
</LinearLayout>
