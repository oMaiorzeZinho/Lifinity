<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/space_gap"
    android:background="@drawable/bg_card_soft_clay"
    android:elevation="5dp"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="@dimen/space_card">

    <!-- Indicador circular: azul se não lida, cinzento se lida (cor definida no adapter) -->
    <View
        android:id="@+id/notificationDot"
        android:layout_width="10dp"
        android:layout_height="10dp"
        android:layout_marginEnd="@dimen/space_gap" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- Texto da mensagem: negrito se não lida, normal se lida -->
        <TextView
            android:id="@+id/notificationMessageText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/lifinity_text"
            android:textSize="15sp"
            tools:text="Completaste uma tarefa e ganhaste XP!" />

        <!-- Data em texto pequeno cinzento -->
        <TextView
            android:id="@+id/notificationDateText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textColor="@color/lifinity_text_secondary"
            android:textSize="12sp"
            tools:text="29/05 · 14:30" />
    </LinearLayout>
</LinearLayout>
