<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app_clay"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:orientation="vertical"
    tools:context=".ProfileActivity">

    <!-- ===== HEADER ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="12dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_pill_mint"
                android:contentDescription="Lifinity"
                android:padding="6dp"
                android:scaleType="centerInside"
                android:src="@drawable/lifinity_logo"
                android:tint="@color/lifinity_primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Lifinity"
                android:textColor="@color/lifinity_text"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/headerNotificationBell"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginEnd="10dp"
            android:background="@drawable/bg_card_soft_clay"
            android:elevation="4dp"
            android:gravity="center"
            android:text="&#128276;"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/headerSettingsIcon"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_card_soft_clay"
            android:elevation="4dp"
            android:gravity="center"
            android:text="⚙"
            android:textSize="16sp" />
    </LinearLayout>

    <!-- ===== CONTEÚDO SCROLLÁVEL ===== -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="8dp">

            <!-- ===== CARTÃO AVATAR + INFO ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_card_clay"
                android:elevation="10dp"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:padding="28dp">

                <!-- Avatar circular clay -->
                <TextView
                    android:id="@+id/profileAvatarText"
                    android:layout_width="104dp"
                    android:layout_height="104dp"
                    android:background="@drawable/bg_avatar_clay"
                    android:gravity="center"
                    android:textColor="@color/lifinity_text_on_primary"
                    android:textSize="44sp"
                    android:textStyle="bold"
                    tools:text="T" />

                <!-- Nome + email -->
                <TextView
                    android:id="@+id/profileUsernameText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:gravity="center"
                    android:textColor="@color/lifinity_text"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    tools:text="Telmo" />

                <TextView
                    android:id="@+id/profileEmailText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:gravity="center"
                    android:textColor="@color/lifinity_text_secondary"
                    android:textSize="14sp"
                    tools:text="telmo@lifinity.pt" />

                <!-- Pills Nível + XP -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_pill_mint"
                        android:elevation="4dp"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp"
                        android:textColor="@color/lifinity_primary"
                        android:textSize="13sp"
                        android:textStyle="bold">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content">
                            NÍVEL
                        </TextView>
                    </TextView>

                    <TextView
                        android:id="@+id/profileLevelText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/bg_pill_mint"
                        android:elevation="4dp"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp"
                        android:textColor="@color/lifinity_primary"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        tools:text="5" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:background="@drawable/bg_pill_alta"
                        android:elevation="4dp"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp"
                        android:textColor="#0E2C1B"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:text="XP" />

                    <TextView
                        android:id="@+id/profileXpText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/bg_pill_alta"
                        android:elevation="4dp"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp"
                        android:textColor="#0E2C1B"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        tools:text="2043" />
                </LinearLayout>

                <!-- Barra de progresso do nível -->
                <TextView
                    android:id="@+id/profileLevelProgressLabel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:gravity="center"
                    android:textColor="@color/lifinity_text_secondary"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    tools:text="219 XP para nível 6" />

                <ProgressBar
                    android:id="@+id/profileLevelProgressBar"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="12dp"
                    android:layout_marginTop="10dp"
                    android:indeterminate="false"
                    android:max="100"
                    android:progress="0"
                    android:progressBackgroundTint="@color/lifinity_inset"
                    android:progressTint="@color/lifinity_primary" />
            </LinearLayout>

            <!-- ===== RESUMO DE ATIVIDADES ===== -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:letterSpacing="0.13"
                android:text="RESUMO DE ATIVIDADES"
                android:textColor="@color/lifinity_text_secondary"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/profileActivitySummaryStatusText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:textColor="@color/lifinity_text_secondary"
                android:textSize="13sp"
                tools:text="A carregar..." />

            <!-- Grid 2x2 de stats -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_card_soft_clay"
                    android:elevation="5dp"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/profileTotalActivitiesText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/lifinity_primary"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        tools:text="12" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:letterSpacing="0.05"
                        android:text="TOTAL"
                        android:textColor="@color/lifinity_text_secondary"
                        android:textSize="11sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_card_soft_clay"
                    android:elevation="5dp"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/profileCompletedActivitiesText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/lifinity_primary"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        tools:text="8" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:letterSpacing="0.05"
                        android:text="CONCLUÍDAS"
                        android:textColor="@color/lifinity_text_secondary"
                        android:textSize="11sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_card_soft_clay"
                    android:elevation="5dp"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/profilePendingActivitiesText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/lifinity_primary"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        tools:text="3" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:letterSpacing="0.05"
                        android:text="PENDENTES"
                        android:textColor="@color/lifinity_text_secondary"
                        android:textSize="11sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_card_soft_clay"
                    android:elevation="5dp"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/profileLostActivitiesText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/lifinity_coral"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        tools:text="1" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:letterSpacing="0.05"
                        android:text="PERDIDAS"
                        android:textColor="@color/lifinity_text_secondary"
                        android:textSize="11sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <!-- ===== CONQUISTAS ===== -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:letterSpacing="0.13"
                android:text="CONQUISTAS"
                android:textColor="@color/lifinity_text_secondary"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/profileAchievementsSummaryText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:textColor="@color/lifinity_text_secondary"
                android:textSize="13sp"
                tools:text="3 de 10 conquistadas" />

            <!-- Achievements (manter IDs existentes) -->
            <LinearLayout
                android:id="@+id/profileAchievement1Container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:background="@drawable/bg_card_soft_clay"
                android:elevation="5dp"
                android:orientation="vertical"
                android:padding="16dp"
                android:visibility="gone"
                tools:visibility="visible">

                <TextView
                    android:id="@+id/profileAchievement1Title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/lifinity_primary"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    tools:text="Primeira atividade" />

                <TextView
                    android:id="@+id/profileAchievement1Description"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="@color/lifinity_text_secondary"
                    android:textSize="13sp"
                    tools:text="Conclui a tua primeira atividade." />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/profileAchievement2Container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:background="@drawable/bg_card_soft_clay"
                android:elevation="5dp"
                android:orientation="vertical"
                android:padding="16dp"
                android:visibility="gone"
                tools:visibility="visible">

                <TextView
                    android:id="@+id/profileAchievement2Title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/lifinity_primary"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    tools:text="Nível 2" />

                <TextView
                    android:id="@+id/profileAchievement2Description"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="@color/lifinity_text_secondary"
                    android:textSize="13sp"
                    tools:text="Chega ao nível 2." />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/profileAchievement3Container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:background="@drawable/bg_card_soft_clay"
                android:elevation="5dp"
                android:orientation="vertical"
                android:padding="16dp"
                android:visibility="gone"
                tools:visibility="visible">

                <TextView
                    android:id="@+id/profileAchievement3Title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/lifinity_primary"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    tools:text="500 XP" />

                <TextView
                    android:id="@+id/profileAchievement3Description"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="@color/lifinity_text_secondary"
                    android:textSize="13sp"
                    tools:text="Acumula 500 XP." />
            </LinearLayout>

            <!-- ===== MENU / HUB ===== -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:letterSpacing="0.13"
                android:text="MAIS NO LIFINITY"
                android:textColor="@color/lifinity_text_secondary"
                android:textSize="11sp"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/profileMenuAssistant"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:background="@drawable/bg_card_soft_clay"
                android:clickable="true"
                android:elevation="5dp"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="14dp">

                <TextView
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:background="@drawable/bg_pill_mint"
                    android:gravity="center"
                    android:text="&#129302;"
                    android:textSize="20sp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Assistente"
                        android:textColor="@color/lifinity_text"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tira dúvidas e organiza tarefas"
                        android:textColor="@color/lifinity_text_secondary"
                        android:textSize="12sp" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="›"
                    android:textColor="@color/lifinity_text_secondary"
                    android:textSize="22sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/profileMenuStatistics"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:background="@drawable/bg_card_soft_clay"
                android:clickable="true"
                android:elevation="5dp"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="14dp">

                <TextView
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:background="@drawable/bg_pill_mint"
                    android:gravity="center"
                    android:text="&#128202;"
                    android:textSize="20sp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Estatísticas"
                        android:textColor="@color/lifinity_text"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Produtividade e progresso"
                        android:textColor="@color/lifinity_text_secondary"
                        android:textSize="12sp" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="›"
                    android:textColor="@color/lifinity_text_secondary"
                    android:textSize="22sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Botões de ação (simplificados) -->
            <Button
                android:id="@+id/profileLogoutButton"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginBottom="8dp"
                android:background="@drawable/btn_danger_clay"
                android:elevation="8dp"
                android:text="Terminar sessão"
                android:textAllCaps="false"
                android:textColor="@color/lifinity_text_on_primary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <!-- Placeholders para botões existentes (ocultos) -->
            <Button
                android:id="@+id/profileTasksButton"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone" />

            <Button
                android:id="@+id/profileAchievementsButton"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone" />

            <Button
                android:id="@+id/profileInspirationButton"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone" />

            <Button
                android:id="@+id/profileSettingsButton"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- ===== BARRA DE NAVEGAÇÃO INFERIOR ===== -->
    <include
        android:id="@+id/bottomNavInclude"
        layout="@layout/nav_bottom"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

</LinearLayout>
