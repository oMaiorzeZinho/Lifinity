<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app_clay"
    android:fillViewport="true"
    tools:context=".ProfileActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/space_screen">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Perfil"
            android:textColor="@color/lifinity_text"
            android:textSize="30sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="O teu progresso no Lifinity."
            android:textColor="@color/lifinity_text_secondary"
            android:textSize="15sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:background="@drawable/bg_card_clay"
            android:elevation="10dp"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="28dp">

            <TextView
                android:id="@+id/profileAvatarText"
                android:layout_width="104dp"
                android:layout_height="104dp"
                android:background="@drawable/bg_avatar_clay"
                android:gravity="center"
                android:textColor="@color/lifinity_text_on_primary"
                android:textSize="44sp"
                android:textStyle="bold"
                tools:text="L" />

            <TextView
                android:id="@+id/profileUsernameText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:gravity="center"
                android:textColor="@color/lifinity_text"
                android:textSize="26sp"
                android:textStyle="bold"
                tools:text="username" />

            <TextView
                android:id="@+id/profileEmailText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="center"
                android:textColor="@color/lifinity_text_secondary"
                android:textSize="15sp"
                tools:text="email@lifinity.pt" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_card_soft_clay"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Nivel"
                        android:textColor="@color/lifinity_text_secondary"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/profileLevelText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:textColor="@color/lifinity_primary"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        tools:text="2" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_card_soft_clay"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="XP"
                        android:textColor="@color/lifinity_text_secondary"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/profileXpText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:textColor="@color/lifinity_primary"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        tools:text="120" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/profileLevelProgressLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:textColor="@color/lifinity_text_secondary"
                android:textSize="13sp"
                android:textStyle="bold"
                tools:text="20 XP para nivel 3" />

            <ProgressBar
                android:id="@+id/profileLevelProgressBar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="12dp"
                android:layout_marginTop="8dp"
                android:indeterminate="false"
                android:max="100"
                android:progress="0"
                android:progressBackgroundTint="@color/lifinity_border"
                android:progressTint="@color/lifinity_primary" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Resumo de atividades"
            android:textColor="@color/lifinity_text"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/profileActivitySummaryStatusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="A carregar atividades..."
            android:textColor="@color/lifinity_text_secondary"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/bg_card_soft_clay"
                android:elevation="5dp"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/profileTotalActivitiesText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/lifinity_primary"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    tools:text="8" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Total"
                    android:textColor="@color/lifinity_text_secondary"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:background="@drawable/bg_card_soft_clay"
                android:elevation="5dp"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/profileCompletedActivitiesText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/lifinity_primary"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    tools:text="4" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Concluidas"
                    android:textColor="@color/lifinity_text_secondary"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/bg_card_soft_clay"
                android:elevation="5dp"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/profilePendingActivitiesText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/lifinity_primary"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    tools:text="3" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Pendentes"
                    android:textColor="@color/lifinity_text_secondary"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:background="@drawable/bg_card_soft_clay"
                android:elevation="5dp"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/profileLostActivitiesText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/lifinity_primary"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    tools:text="1" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Perdidas"
                    android:textColor="@color/lifinity_text_secondary"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Conquistas"
            android:textColor="@color/lifinity_text"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/profileAchievementsSummaryText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="A carregar conquistas..."
            android:textColor="@color/lifinity_text_secondary"
            android:textSize="14sp" />

        <LinearLayout
            android:id="@+id/profileAchievement1Container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_card_soft_clay"
            android:elevation="5dp"
            android:orientation="vertical"
            android:padding="16dp"
            android:visibility="gone"
            tools:visibility="visible">

            <TextView
                android:id="@+id/profileAchievement1Title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/lifinity_primary"
                android:textSize="15sp"
                android:textStyle="bold"
                tools:text="Primeira atividade" />

            <TextView
                android:id="@+id/profileAchievement1Description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/lifinity_text_secondary"
                android:textSize="13sp"
                tools:text="Conclui a tua primeira atividade." />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/profileAchievement2Container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_card_soft_clay"
            android:elevation="5dp"
            android:orientation="vertical"
            android:padding="16dp"
            android:visibility="gone"
            tools:visibility="visible">

            <TextView
                android:id="@+id/profileAchievement2Title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/lifinity_primary"
                android:textSize="15sp"
                android:textStyle="bold"
                tools:text="Nivel 2" />

            <TextView
                android:id="@+id/profileAchievement2Description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/lifinity_text_secondary"
                android:textSize="13sp"
                tools:text="Chega ao nivel 2." />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/profileAchievement3Container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_card_soft_clay"
            android:elevation="5dp"
            android:orientation="vertical"
            android:padding="16dp"
            android:visibility="gone"
            tools:visibility="visible">

            <TextView
                android:id="@+id/profileAchievement3Title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/lifinity_primary"
                android:textSize="15sp"
                android:textStyle="bold"
                tools:text="500 XP" />

            <TextView
                android:id="@+id/profileAchievement3Description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/lifinity_text_secondary"
                android:textSize="13sp"
                tools:text="Acumula 500 XP." />
        </LinearLayout>

        <Button
            android:id="@+id/profileTasksButton"
            android:layout_width="match_parent"
            android:layout_height="@dimen/height_button"
            android:layout_marginTop="24dp"
            android:background="@drawable/btn_primary_clay"
            android:elevation="8dp"
            android:text="Ver atividades"
            android:textAllCaps="false"
            android:textColor="@color/lifinity_text_on_primary"
            android:textSize="16sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/profileAchievementsButton"
            android:layout_width="match_parent"
            android:layout_height="@dimen/height_button"
            android:layout_marginTop="14dp"
            android:background="@drawable/btn_secondary_clay"
            android:elevation="6dp"
            android:text="Todas as conquistas"
            android:textAllCaps="false"
            android:textColor="@color/lifinity_text"
            android:textSize="16sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/profileInspirationButton"
            android:layout_width="match_parent"
            android:layout_height="@dimen/height_button"
            android:layout_marginTop="14dp"
            android:background="@drawable/btn_secondary_clay"
            android:elevation="6dp"
            android:text="Inspiracao"
            android:textAllCaps="false"
            android:textColor="@color/lifinity_text"
            android:textSize="16sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/profileSettingsButton"
            android:layout_width="match_parent"
            android:layout_height="@dimen/height_button"
            android:layout_marginTop="14dp"
            android:background="@drawable/btn_secondary_clay"
            android:elevation="6dp"
            android:text="Configuracoes"
            android:textAllCaps="false"
            android:textColor="@color/lifinity_text"
            android:textSize="16sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/profileLogoutButton"
            android:layout_width="match_parent"
            android:layout_height="@dimen/height_button"
            android:layout_marginTop="14dp"
            android:background="@drawable/btn_danger_clay"
            android:elevation="6dp"
            android:text="Terminar sessao"
            android:textAllCaps="false"
            android:textColor="@color/lifinity_text_on_primary"
            android:textSize="16sp"
            android:textStyle="bold" />
    </LinearLayout>
</ScrollView>
