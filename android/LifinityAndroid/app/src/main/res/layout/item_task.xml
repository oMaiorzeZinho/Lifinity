<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    android:background="@drawable/bg_card_clay"
    android:elevation="8dp"
    android:orientation="vertical"
    android:padding="@dimen/space_card">

    <TextView
        android:id="@+id/taskTitleText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/lifinity_text"
        android:textSize="18sp"
        android:textStyle="bold"
        tools:text="Estudar Android" />

    <TextView
        android:id="@+id/taskDescriptionText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textColor="@color/lifinity_text_secondary"
        android:textSize="14sp"
        tools:text="Rever Retrofit e RecyclerView." />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:background="@drawable/bg_card_soft_clay"
        android:orientation="vertical"
        android:padding="14dp">

        <TextView
            android:id="@+id/taskPriorityText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/lifinity_primary"
            android:textSize="13sp"
            android:textStyle="bold"
            tools:text="Prioridade: media" />

        <TextView
            android:id="@+id/taskStatusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textColor="@color/lifinity_text"
            android:textSize="13sp"
            android:textStyle="bold"
            tools:text="Estado: pendente" />

        <TextView
            android:id="@+id/taskDueDateText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textColor="@color/lifinity_text_secondary"
            android:textSize="13sp"
            tools:text="Data limite: 2026-05-19" />

        <TextView
            android:id="@+id/taskCreatedAtText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/lifinity_text_secondary"
            android:textSize="12sp"
            tools:text="Criada em: 2026-05-19T12:00:00.000Z" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/taskCompleteButton"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:background="@drawable/btn_primary_clay"
            android:elevation="6dp"
            android:text="Concluir"
            android:textAllCaps="false"
            android:textColor="@color/lifinity_text_on_primary"
            android:textSize="15sp"
            android:textStyle="bold"
            tools:visibility="visible" />

        <Button
            android:id="@+id/taskOptionsButton"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:background="@drawable/btn_secondary_clay"
            android:elevation="6dp"
            android:text="Opcoes"
            android:textAllCaps="false"
            android:textColor="@color/lifinity_text"
            android:textSize="15sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
