<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="#0D1A14"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/taskTitleText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#F4FBF7"
        android:textSize="18sp"
        android:textStyle="bold"
        tools:text="Estudar Android" />

    <TextView
        android:id="@+id/taskDescriptionText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textColor="#B5C7BC"
        android:textSize="14sp"
        tools:text="Rever Retrofit e RecyclerView." />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/taskPriorityText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#7FE0A4"
            android:textSize="13sp"
            android:textStyle="bold"
            tools:text="Prioridade: media" />

        <TextView
            android:id="@+id/taskStatusText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:gravity="end"
            android:textColor="#F4FBF7"
            android:textSize="13sp"
            android:textStyle="bold"
            tools:text="Estado: pendente" />
    </LinearLayout>

    <TextView
        android:id="@+id/taskDueDateText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:textColor="#B5C7BC"
        android:textSize="13sp"
        tools:text="Data limite: 2026-05-19" />

    <TextView
        android:id="@+id/taskCreatedAtText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textColor="#637166"
        android:textSize="12sp"
        tools:text="Criada em: 2026-05-19T12:00:00.000Z" />

</LinearLayout>
