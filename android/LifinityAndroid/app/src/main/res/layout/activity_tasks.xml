<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#07110D"
    android:orientation="vertical"
    android:padding="20dp"
    tools:context=".TasksActivity">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tarefas"
        android:textColor="#F4FBF7"
        android:textSize="28sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="As tuas tarefas do Lifinity"
        android:textColor="#B5C7BC"
        android:textSize="15sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/createTaskButton"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:backgroundTint="#7FE0A4"
            android:text="Nova tarefa"
            android:textAllCaps="false"
            android:textColor="#07110D"
            android:textSize="15sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/hideCompletedTasksButton"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:backgroundTint="#26372D"
            android:text="Ocultar concluidas"
            android:textAllCaps="false"
            android:textColor="#F4FBF7"
            android:textSize="15sp"
            android:textStyle="bold" />
    </LinearLayout>

    <EditText
        android:id="@+id/tasksSearchInput"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="16dp"
        android:background="#F4FBF7"
        android:hint="Pesquisar por titulo"
        android:inputType="text"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:singleLine="true"
        android:textColor="#07110D"
        android:textColorHint="#637166"
        android:textSize="15sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Estado"
                android:textColor="#B5C7BC"
                android:textSize="12sp"
                android:textStyle="bold" />

            <Spinner
                android:id="@+id/tasksStatusFilterSpinner"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="6dp"
                android:background="#F4FBF7"
                android:paddingStart="12dp"
                android:paddingEnd="12dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Prioridade"
                android:textColor="#B5C7BC"
                android:textSize="12sp"
                android:textStyle="bold" />

            <Spinner
                android:id="@+id/tasksPriorityFilterSpinner"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="6dp"
                android:background="#F4FBF7"
                android:paddingStart="12dp"
                android:paddingEnd="12dp" />
        </LinearLayout>
    </LinearLayout>

    <ProgressBar
        android:id="@+id/tasksProgressBar"
        style="?android:attr/progressBarStyleLarge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="40dp"
        android:indeterminateTint="#7FE0A4"
        android:visibility="gone" />

    <TextView
        android:id="@+id/tasksErrorText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="34dp"
        android:gravity="center"
        android:textColor="#FFB4AB"
        android:textSize="15sp"
        android:textStyle="bold"
        android:visibility="gone"
        tools:text="Erro ao carregar tarefas."
        tools:visibility="visible" />

    <TextView
        android:id="@+id/tasksEmptyText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="34dp"
        android:gravity="center"
        android:text="Ainda não tens tarefas."
        android:textColor="#B5C7BC"
        android:textSize="16sp"
        android:visibility="gone"
        tools:visibility="visible" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/tasksRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="22dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="12dp"
        android:visibility="gone"
        tools:listitem="@layout/item_task"
        tools:visibility="visible" />

</LinearLayout>
