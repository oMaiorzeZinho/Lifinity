<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#07110D"
    android:orientation="vertical"
    android:padding="20dp"
    tools:context=".TasksActivity">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tarefas"
        android:textColor="#F4FBF7"
        android:textSize="28sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="As tuas tarefas do Lifinity"
        android:textColor="#B5C7BC"
        android:textSize="15sp" />

    <ProgressBar
        android:id="@+id/tasksProgressBar"
        style="?android:attr/progressBarStyleLarge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="40dp"
        android:indeterminateTint="#7FE0A4"
        android:visibility="gone" />

    <TextView
        android:id="@+id/tasksErrorText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="34dp"
        android:gravity="center"
        android:textColor="#FFB4AB"
        android:textSize="15sp"
        android:textStyle="bold"
        android:visibility="gone"
        tools:text="Erro ao carregar tarefas."
        tools:visibility="visible" />

    <TextView
        android:id="@+id/tasksEmptyText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="34dp"
        android:gravity="center"
        android:text="Ainda não tens tarefas."
        android:textColor="#B5C7BC"
        android:textSize="16sp"
        android:visibility="gone"
        tools:visibility="visible" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/tasksRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="22dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="12dp"
        android:visibility="gone"
        tools:listitem="@layout/item_task"
        tools:visibility="visible" />

</LinearLayout>
