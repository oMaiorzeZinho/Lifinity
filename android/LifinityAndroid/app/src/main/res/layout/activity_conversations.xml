<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app_clay"
    android:orientation="vertical"
    tools:context=".ConversationsActivity">

    <!-- ===== CABEÇALHO COM BOTÃO VOLTAR ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="12dp">

        <TextView
            android:id="@+id/conversationsBackButton"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:background="@drawable/bg_card_soft_clay"
            android:elevation="4dp"
            android:gravity="center"
            android:text="‹"
            android:textColor="@color/lifinity_text"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_weight="1"
            android:text="Chat"
            android:textColor="@color/lifinity_text"
            android:textSize="20sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Subtítulo -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingBottom="12dp"
        android:text="As tuas conversas."
        android:textColor="@color/lifinity_text_secondary"
        android:textSize="14sp" />

    <!-- Loading -->
    <ProgressBar
        android:id="@+id/conversationsProgressBar"
        style="?android:attr/progressBarStyleLarge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="32dp"
        android:indeterminateTint="@color/lifinity_primary"
        android:visibility="gone" />

    <!-- Mensagem de erro -->
    <TextView
        android:id="@+id/conversationsErrorText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginTop="16dp"
        android:gravity="center"
        android:textColor="@color/lifinity_danger"
        android:textSize="15sp"
        android:textStyle="bold"
        android:visibility="gone"
        tools:text="Não foi possível carregar conversas."
        tools:visibility="visible" />

    <!-- Lista vazia -->
    <TextView
        android:id="@+id/conversationsEmptyText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_card_soft_clay"
        android:gravity="center"
        android:padding="24dp"
        android:text="Ainda não tens conversas."
        android:textColor="@color/lifinity_text_secondary"
        android:textSize="15sp"
        android:visibility="gone"
        tools:visibility="visible" />

    <!-- Lista de conversas -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/conversationsRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="4dp"
        android:paddingBottom="20dp"
        android:visibility="gone"
        tools:listitem="@layout/item_conversation"
        tools:visibility="visible" />
</LinearLayout>
