<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app_clay"
    android:orientation="vertical"
    tools:context=".NotificationsActivity">

    <!-- ===== HEADER ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="12dp">

        <TextView
            android:id="@+id/notificationsBackButton"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:background="@drawable/bg_card_soft_clay"
            android:elevation="4dp"
            android:gravity="center"
            android:text="‹"
            android:textColor="@color/lifinity_text"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_weight="1"
            android:text="Notificações"
            android:textColor="@color/lifinity_text"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/notificationsMarkAllButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_pill_mint"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:text="Marcar lidas"
            android:textColor="@color/lifinity_primary"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingBottom="12dp"
        android:text="As tuas notificações mais recentes."
        android:textColor="@color/lifinity_text_secondary"
        android:textSize="14sp" />

    <ProgressBar
        android:id="@+id/notificationsProgressBar"
        style="?android:attr/progressBarStyleLarge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="24dp"
        android:indeterminateTint="@color/lifinity_primary"
        android:visibility="gone" />

    <TextView
        android:id="@+id/notificationsEmptyText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginTop="24dp"
        android:background="@drawable/bg_card_soft_clay"
        android:gravity="center"
        android:padding="24dp"
        android:text="Ainda não tens notificações."
        android:textColor="@color/lifinity_text_secondary"
        android:textSize="15sp"
        android:visibility="gone"
        tools:visibility="visible" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/notificationsRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="4dp"
        android:paddingBottom="20dp"
        tools:listitem="@layout/item_notification" />
</LinearLayout>
