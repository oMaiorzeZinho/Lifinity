<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app_clay"
    android:fillViewport="true"
    tools:context=".RegisterActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="@dimen/space_screen">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card_clay"
            android:elevation="10dp"
            android:orientation="vertical"
            android:padding="28dp">

            <ImageView
                android:layout_width="78dp"
                android:layout_height="78dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_pill_mint"
                android:contentDescription="Lifinity"
                android:padding="16dp"
                android:scaleType="centerInside"
                android:src="@drawable/lifinity_logo"
                android:tint="@color/lifinity_primary" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:letterSpacing="0.04"
                android:text="Lifinity"
                android:textColor="@color/lifinity_primary"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:gravity="center"
                android:text="Criar conta"
                android:textColor="@color/lifinity_text"
                android:textSize="30sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:text="Regista-te para comecar a organizar as tuas atividades."
                android:textColor="@color/lifinity_text_secondary"
                android:textSize="15sp" />

            <EditText
                android:id="@+id/registerUsernameInput"
                android:layout_width="match_parent"
                android:layout_height="@dimen/height_input"
                android:layout_marginTop="30dp"
                android:autofillHints="username"
                android:background="@drawable/bg_input_clay"
                android:hint="Username"
                android:inputType="text"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:singleLine="true"
                android:textColor="@color/lifinity_text"
                android:textColorHint="@color/lifinity_text_faint"
                android:textSize="16sp" />

            <EditText
                android:id="@+id/registerEmailInput"
                android:layout_width="match_parent"
                android:layout_height="@dimen/height_input"
                android:layout_marginTop="14dp"
                android:autofillHints="emailAddress"
                android:background="@drawable/bg_input_clay"
                android:hint="Email"
                android:inputType="textEmailAddress"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:singleLine="true"
                android:textColor="@color/lifinity_text"
                android:textColorHint="@color/lifinity_text_faint"
                android:textSize="16sp" />

            <EditText
                android:id="@+id/registerPasswordInput"
                android:layout_width="match_parent"
                android:layout_height="@dimen/height_input"
                android:layout_marginTop="14dp"
                android:autofillHints="newPassword"
                android:background="@drawable/bg_input_clay"
                android:hint="Palavra-passe"
                android:inputType="textPassword"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:singleLine="true"
                android:textColor="@color/lifinity_text"
                android:textColorHint="@color/lifinity_text_faint"
                android:textSize="16sp" />

            <EditText
                android:id="@+id/registerConfirmPasswordInput"
                android:layout_width="match_parent"
                android:layout_height="@dimen/height_input"
                android:layout_marginTop="14dp"
                android:autofillHints="newPassword"
                android:background="@drawable/bg_input_clay"
                android:hint="Confirmar palavra-passe"
                android:inputType="textPassword"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:singleLine="true"
                android:textColor="@color/lifinity_text"
                android:textColorHint="@color/lifinity_text_faint"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/registerErrorText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:gravity="center"
                android:textColor="@color/lifinity_danger"
                android:textSize="14sp"
                android:textStyle="bold"
                android:visibility="gone"
                tools:text="Erro ao criar conta."
                tools:visibility="visible" />

            <Button
                android:id="@+id/registerButton"
                android:layout_width="match_parent"
                android:layout_height="@dimen/height_button"
                android:layout_marginTop="20dp"
                android:background="@drawable/btn_primary_clay"
                android:elevation="8dp"
                android:text="Criar conta"
                android:textAllCaps="false"
                android:textColor="@color/lifinity_text_on_primary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/backToLoginButton"
                android:layout_width="match_parent"
                android:layout_height="@dimen/height_button"
                android:layout_marginTop="14dp"
                android:background="@drawable/btn_secondary_clay"
                android:elevation="6dp"
                android:text="Ja tenho conta"
                android:textAllCaps="false"
                android:textColor="@color/lifinity_text"
                android:textSize="16sp"
                android:textStyle="bold" />

            <ProgressBar
                android:id="@+id/registerProgressBar"
                style="?android:attr/progressBarStyleSmall"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="18dp"
                android:indeterminateTint="@color/lifinity_primary"
                android:visibility="gone" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
