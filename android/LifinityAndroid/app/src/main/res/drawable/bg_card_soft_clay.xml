<?xml version="1.0" encoding="utf-8"?>
<!-- Sub-cartão clay (dentro de cartões): raio 22dp, shadow mais suave -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item
        android:bottom="3dp"
        android:right="3dp">
        <shape>
            <solid android:color="#1896CDA5" />
            <corners android:radius="22dp" />
        </shape>
    </item>
    <item>
        <shape>
            <gradient
                android:angle="152"
                android:startColor="@color/lifinity_surface2"
                android:endColor="@color/lifinity_surface" />
            <corners android:radius="22dp" />
        </shape>
    </item>
</layer-list>
