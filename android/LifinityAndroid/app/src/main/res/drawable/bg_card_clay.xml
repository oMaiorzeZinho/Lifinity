<?xml version="1.0" encoding="utf-8"?>
<!-- CartĂŁo clay principal: gradiente surface2â†’surface, raio 30dp -->
<!-- A sombra drop Ă© controlada por android:elevation no layout -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Camada de realce superior-esquerdo (glow clay) -->
    <item
        android:bottom="4dp"
        android:right="4dp">
        <shape>
            <solid android:color="#1596CDA5" />
            <corners android:radius="30dp" />
        </shape>
    </item>
    <!-- SuperfĂ­cie principal com gradiente -->
    <item>
        <shape>
            <gradient
                android:angle="152"
                android:startColor="@color/lifinity_surface2"
                android:endColor="@color/lifinity_surface" />
            <corners android:radius="30dp" />
        </shape>
    </item>
</layer-list>
