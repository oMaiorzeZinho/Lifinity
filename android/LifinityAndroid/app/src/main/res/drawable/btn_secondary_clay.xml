<?xml version="1.0" encoding="utf-8"?>
<!-- Botão secundário clay: gradiente surface, raio 16dp -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <gradient
                android:angle="152"
                android:startColor="@color/lifinity_surface"
                android:endColor="#1E2F24" />
            <corners android:radius="@dimen/radius_control" />
        </shape>
    </item>
    <item>
        <layer-list>
            <item
                android:bottom="5dp"
                android:right="5dp">
                <shape>
                    <solid android:color="#0F96CDA5" />
                    <corners android:radius="@dimen/radius_control" />
                </shape>
            </item>
            <item>
                <shape>
                    <gradient
                        android:angle="152"
                        android:startColor="@color/lifinity_surface2"
                        android:endColor="@color/lifinity_surface" />
                    <corners android:radius="@dimen/radius_control" />
                </shape>
            </item>
        </layer-list>
    </item>
</selector>
