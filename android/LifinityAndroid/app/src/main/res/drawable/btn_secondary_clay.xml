<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <solid android:color="@color/lifinity_card" />
            <corners android:radius="@dimen/radius_control" />
            <stroke
                android:width="1dp"
                android:color="@color/lifinity_primary" />
        </shape>
    </item>
    <item>
        <shape>
            <solid android:color="@color/lifinity_card_soft" />
            <corners android:radius="@dimen/radius_control" />
            <stroke
                android:width="1dp"
                android:color="@color/lifinity_border" />
        </shape>
    </item>
</selector>
