<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.Theme.Lifinity" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- sans-serif-rounded é o substituto do Nunito disponível em todos os Android -->
        <item name="android:fontFamily">sans-serif-rounded</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:statusBarColor">@color/lifinity_bg</item>
        <item name="android:navigationBarColor">@color/lifinity_bg</item>
        <item name="colorPrimary">@color/lifinity_primary</item>
        <item name="colorPrimaryContainer">@color/lifinity_surface2</item>
        <item name="colorOnPrimary">@color/lifinity_text_on_primary</item>
        <item name="colorSurface">@color/lifinity_surface</item>
        <item name="colorOnSurface">@color/lifinity_text</item>
        <item name="colorBackground">@color/lifinity_bg</item>
        <item name="android:colorBackground">@color/lifinity_bg</item>
        <item name="colorError">@color/lifinity_coral</item>
    </style>

    <style name="Theme.Lifinity" parent="Base.Theme.Lifinity" />
</resources>
